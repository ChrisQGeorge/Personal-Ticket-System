# =============================================================================
# Personal Ticket System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run: cp .env.template .env   (or use the setup script: bash setup.sh)
#
# IMPORTANT: Never commit .env to git. Only .env.template should be tracked.
# =============================================================================

# --- Database ----------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=pts_db
MYSQL_USER=pts_user
MYSQL_PASSWORD=CHANGE_ME_db_password

# --- Backend -----------------------------------------------------------------
# These must match the MySQL values above
DB_HOST=db
DB_PORT=3306
DB_USER=pts_user
DB_PASS=CHANGE_ME_db_password
DB_NAME=pts_db

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=CHANGE_ME_jwt_secret

# JWT token expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# Fernet encryption key for encrypting sensitive data in the database
# (e.g., IMAP passwords). Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_key

# CORS allowed origins (comma-separated). Set to your frontend URL.
# WARNING: Never use "*" — it disables CORS protection entirely.
ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" if serving over HTTPS (marks auth cookies as Secure)
COOKIE_SECURE=false

# --- Frontend ----------------------------------------------------------------
BACKEND_URL=http://backend:8000

# Bind address for the frontend (default: 0.0.0.0 for LAN access)
# Set to 127.0.0.1 to restrict to localhost only
FRONTEND_BIND=0.0.0.0
